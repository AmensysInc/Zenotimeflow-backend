# Copy to .env and fill in values. Never commit .env to version control.
# cp .env.example .env   (Linux/Mac)  or  copy .env.example .env   (Windows)

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
SECRET_KEY=your-secret-key-min-50-chars-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# MySQL Database Configuration (Production SaaS)
# ---------------------------------------------------------------------------
# Database: zenotimeflow_db (created via MySQL client)
# USE_SQLITE=0 to enable MySQL, USE_SQLITE=1 for SQLite (development fallback)
USE_SQLITE=0
DB_NAME=zenotimeflow_db
DB_USER=zenotimeflow_user
DB_PASSWORD=your_secure_mysql_password
DB_HOST=localhost
DB_PORT=3306
# Connection pooling: 0=close after request (dev), 60-600 for production
DB_CONN_MAX_AGE=0

# ---------------------------------------------------------------------------
# CORS (comma-separated origins)
# ---------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Optional: Email, etc.
# ---------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@zenotimeflow.com
